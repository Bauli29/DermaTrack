#!/usr/bin/env sh
set -e

repo_root=$(git rev-parse --show-toplevel)

has_changes() {
  ! git diff --cached --quiet --diff-filter=ACMR -- "$@"
}

frontend_changed=false
backend_changed=false

if has_changes frontend/src frontend/package.json frontend/next.config.ts frontend/eslint.config.mjs frontend/tsconfig.json frontend/pnpm-lock.yaml; then
  frontend_changed=true
fi

if has_changes backend/src backend/pom.xml backend/mvnw backend/mvnw.cmd backend/Dockerfile; then
  backend_changed=true
fi

if [ "$frontend_changed" = false ] && [ "$backend_changed" = false ]; then
  echo "No frontend or backend product code changes detected. Skipping checks."
  exit 0
fi

if [ "$frontend_changed" = true ]; then
  echo "Running frontend checks..."
  cd "$repo_root/frontend"

  echo "Checking code formatting..."
  pnpm run format:check

  echo "Running lint check..."
  pnpm run lint:check
fi

if [ "$backend_changed" = true ]; then
  echo ""
  echo "Running backend tests..."
  cd "$repo_root/backend"

  if [ -f "./mvnw" ]; then
    ./mvnw test
  elif [ -f "./mvnw.cmd" ]; then
    ./mvnw.cmd test
  elif command -v mvn > /dev/null 2>&1; then
    mvn test
  else
    echo "ERROR: No Maven wrapper or mvn found. Cannot run backend tests." >&2
    exit 1
  fi
fi

echo ""
echo "Relevant pre-commit checks passed."